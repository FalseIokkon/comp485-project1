<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.yunzog.dashboard.MainController">

    <top>
        <HBox spacing="12">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label text="Yunzog CEO Dashboard"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#onRefresh"/>
        </HBox>
    </top>

    <center>
        <TabPane>
            <Tab text="Overview" closable="false">
                <BorderPane>
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>

                    <center>
                        <TableView fx:id="table">
                            <columns>
                                <TableColumn fx:id="divisionCol" text="Division" prefWidth="180"/>
                                <TableColumn fx:id="metricCol" text="Metric" prefWidth="420"/>
                                <TableColumn fx:id="valueCol" text="Value" prefWidth="160"/>
                                <TableColumn fx:id="asOfCol" text="As Of" prefWidth="160"/>
                            </columns>
                        </TableView>
                    </center>
                </BorderPane>
            </Tab>

            <Tab text="HR" closable="false"/>
            <Tab text="Finance" closable="false"/>
            <Tab text="Administration" closable="false"/>
            <Tab text="Marketing" closable="false"/>
            <Tab text="Manufacturing" closable="false"/>
            <Tab text="Distributing" closable="false"/>
        </TabPane>
    </center>
</BorderPane>