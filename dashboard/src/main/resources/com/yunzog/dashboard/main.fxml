<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.yunzog.dashboard.MainController"
            style="-fx-background-color: #121212;">

    <top>
        <HBox spacing="12" style="-fx-background-color: #1f1f1f;">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <VBox spacing="4">
                <Label text="Yunzog CEO Dashboard"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
                <Label text="Executive overview of all divisions"
                       style="-fx-font-size: 12px; -fx-text-fill: #bdbdbd;" />
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button fx:id="refreshButton"
                        text="Refresh"
                        onAction="#onRefresh"
                        focusTraversable="false"/>
                <Button text="Exit"
                        onAction="#onExit"
                        focusTraversable="false"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Overview">
                    <content>
                        <fx:include source="overview-tab.fxml"/>
                    </content>
                </Tab>

                <Tab text="HR">
                    <content>
                        <fx:include source="hr-tab.fxml"/>
                    </content>
                </Tab>

                <Tab text="Finance">
                    <content>
                        <fx:include source="finance-tab.fxml"/>
                    </content>
                </Tab>

                <Tab text="Marketing">
                    <content>
                        <fx:include source="marketing-tab.fxml"/>
                    </content>
                </Tab>

                <Tab text="Manufacturing">
                    <content>
                        <fx:include source="manufacturing-tab.fxml"/>
                    </content>
                </Tab>

                <Tab text="Distributing">
                    <content>
                        <fx:include source="distribution-tab.fxml"/>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>