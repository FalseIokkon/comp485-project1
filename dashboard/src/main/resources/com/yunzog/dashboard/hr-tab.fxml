<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.yunzog.dashboard.controller.HRController"
            style="-fx-background-color: #121212;">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <top>
        <FlowPane hgap="16" vgap="16">
            <BorderPane.margin>
                <Insets bottom="16"/>
            </BorderPane.margin>

            <VBox spacing="6"
                  prefWidth="180"
                  style="-fx-background-color: #1f1f1f; -fx-background-radius: 10; -fx-padding: 16;">
                <Label text="Total Employees"
                       style="-fx-font-size: 13px; -fx-text-fill: #bdbdbd;" />
                <Label fx:id="totalEmployeesLabel"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
            </VBox>

            <VBox spacing="6"
                  prefWidth="180"
                  style="-fx-background-color: #1f1f1f; -fx-background-radius: 10; -fx-padding: 16;">
                <Label text="Open Positions"
                       style="-fx-font-size: 13px; -fx-text-fill: #bdbdbd;" />
                <Label fx:id="openPositionsLabel"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
            </VBox>

            <VBox spacing="6"
                  prefWidth="180"
                  style="-fx-background-color: #1f1f1f; -fx-background-radius: 10; -fx-padding: 16;">
                <Label text="Hires This Month"
                       style="-fx-font-size: 13px; -fx-text-fill: #bdbdbd;" />
                <Label fx:id="hiresThisMonthLabel"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
            </VBox>

            <VBox spacing="6"
                  prefWidth="180"
                  style="-fx-background-color: #1f1f1f; -fx-background-radius: 10; -fx-padding: 16;">
                <Label text="Attendance Rate"
                       style="-fx-font-size: 13px; -fx-text-fill: #bdbdbd;" />
                <Label fx:id="attendanceRateLabel"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
            </VBox>

            <VBox spacing="6"
                  prefWidth="180"
                  style="-fx-background-color: #1f1f1f; -fx-background-radius: 10; -fx-padding: 16;">
                <Label text="Avg. Performance Rating"
                       style="-fx-font-size: 13px; -fx-text-fill: #bdbdbd;" />
                <Label fx:id="avgPerformanceLabel"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
            </VBox>
        </FlowPane>
    </top>

    <center>
        <VBox spacing="16">

            <HBox alignment="CENTER">
                <BarChart fx:id="hiresChart"
                          title="Hires by Month"
                          categoryGap="16"
                          barGap="8"
                          legendVisible="false"
                          animated="false"
                          prefWidth="700"
                          prefHeight="260">
                    <xAxis>
                        <CategoryAxis label="Month"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Hires"/>
                    </yAxis>
                </BarChart>
            </HBox>

            <VBox spacing="10" VBox.vgrow="ALWAYS">
                <Label text="Employee Directory"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" />

                <TableView fx:id="employeeTable"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #1f1f1f;">
                    <columns>
                        <TableColumn fx:id="nameCol" text="Name"/>
                        <TableColumn fx:id="titleCol" text="Title"/>
                        <TableColumn fx:id="departmentCol" text="Department"/>
                        <TableColumn fx:id="branchCol" text="Branch"/>
                        <TableColumn fx:id="statusCol" text="Status"/>
                        <TableColumn fx:id="hireDateCol" text="Hire Date"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>